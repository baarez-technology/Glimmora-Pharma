# Glimmora Pharma — environment variables template
#
# Copy this file to `.env` (or `.env.local`) and fill in real values.
# Both `.env` and `.env.local` are gitignored.
#
# In production, set these in DigitalOcean App Platform → App Settings → Environment Variables.

# ─── Prisma database ────────────────────────────────────────────────────────
# Local dev: SQLite
# Production (DigitalOcean Managed PostgreSQL):
#   postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="file:./dev.db"

# ─── NextAuth (in-app authentication) ───────────────────────────────────────
# CRITICAL: generate a real value with `openssl rand -base64 32`.
# Production will refuse to boot with the placeholder, an empty value, or
# anything shorter than 32 characters. Dev allows the placeholder.
NEXTAUTH_SECRET=replace-with-a-32-byte-base64-secret

# Local dev:   http://localhost:3000
# Production:  https://your-app.ondigitalocean.app  (or your custom domain)
NEXTAUTH_URL=http://localhost:3000

# ─── Email / SMTP (transactional mail, MFA OTP) ─────────────────────────────
# In dev, leaving these blank is safe: the mailer logs to the server console
# instead of sending. In production, the mailer throws on load if missing.

# Gmail address used to send OTP emails
GMAIL_USER=

# Gmail App Password (NOT your account password).
# Generate at: Google Account → Security → 2-Step Verification → App passwords
GMAIL_APP_PASSWORD=

# ─── AI backend ─────────────────────────────────────────────────────────────
# Public URL the browser uses for direct AI calls (with /api suffix).
NEXT_PUBLIC_API_URL=https://pharma-glimmora-ai-backend.onrender.com/api

# Server-side base URL for the AI proxy (no /api suffix).
# On DigitalOcean App Platform this is set to ${api.PRIVATE_URL} so the
# Next.js server reaches FastAPI over DO's internal network — never the
# public internet. Local dev defaults to http://localhost:8000.
BACKEND_URL=http://localhost:8000

# ─── Keycloak OIDC (optional — leave blank to disable) ──────────────────────
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ISSUER=

# ─── File storage ───────────────────────────────────────────────────────────
# "local"      — local filesystem ./uploads/ (dev default)
# "do-spaces"  — DigitalOcean Spaces (required on App Platform)
FILE_STORAGE_BACKEND=local

# Required when FILE_STORAGE_BACKEND=do-spaces
# Create a Spaces bucket in the same region as your App Platform app.
# Keys: DigitalOcean → API → Spaces Keys → Generate New Key
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=glimmora-pharma-files
