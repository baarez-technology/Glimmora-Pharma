// ── EVIDENCE COLLECTION (CAPA substage 3.2) ──
// Structured evidence collection during CAPA investigation per the GxP
// reference: 21 CFR 820.100(a)(2), 21 CFR 211.192, ICH Q10 §3.2.2,
// EU GMP Ch.1 §1.4(xiv), 21 CFR Part 11. Designed to satisfy ALCOA+.

// EvidenceItem.category — allowed values:
//   BATCH_RECORDS, TRAINING_RECORDS, EQUIPMENT_LOGS, ENVIRONMENTAL_DATA,
//   DEVIATION_HISTORY, WITNESS_INTERVIEWS, SUPPLIER_DATA
// EvidenceItem.status — allowed values:
//   PENDING, IN_PROGRESS, COMPLETE, NOT_APPLICABLE
// (No native enums: SQLite + Prisma uses string fields with Zod runtime
// validation — same pattern as CAPA.risk, Finding.severity, etc.)
model EvidenceItem {
  id                String   @id @default(cuid())
  capaId            String
  category          String
  status            String   @default("PENDING")
  notes             String?

  // Wave 3 e-sig lock placeholder (unused in v1; schema-stable for future).
  // When set, all mutations on this EvidenceItem and its files are rejected.
  lockedAt          DateTime?
  lockedBy          String?
  lockedSignatureId String?

  createdBy         String
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  capa              CAPA                  @relation(fields: [capaId], references: [id], onDelete: Cascade)
  files             EvidenceFile[]
  noteVersions      EvidenceNoteVersion[]

  @@unique([capaId, category])
  @@index([capaId])
}

// EvidenceNoteVersion — immutable historical snapshots of EvidenceItem.notes.
// Inserted (never updated) on every notes change so the prior value is
// preserved per ALCOA+ Original. statusAtTime captures the EvidenceItem.status
// at the moment the snapshot was taken.
model EvidenceNoteVersion {
  id              String   @id @default(cuid())
  evidenceItemId  String
  notes           String
  statusAtTime    String
  createdBy       String
  createdAt       DateTime @default(now())

  evidenceItem    EvidenceItem @relation(fields: [evidenceItemId], references: [id], onDelete: Cascade)

  @@index([evidenceItemId])
}

// EvidenceFile — soft-delete only per Part 11 immutability. The actual file
// on disk is preserved per ALCOA+ Enduring; deletion is metadata-only via
// (deletedAt, deletedBy, deletionReason). retainUntil is enforced server-side
// — uploads default to +7 years (conservative baseline for "≥5 years post
// product expiry" per the PDF substage 8.4 spec).
model EvidenceFile {
  id                String   @id @default(cuid())
  evidenceItemId    String
  fileName          String
  originalFileName  String
  fileSize          Int
  fileType          String
  fileExtension     String
  fileUrl           String
  contentHashSha256 String
  retainUntil       DateTime

  // Soft delete metadata
  deletedAt         DateTime?
  deletedBy         String?
  deletionReason    String?

  uploadedBy        String
  createdAt         DateTime @default(now())

  evidenceItem      EvidenceItem @relation(fields: [evidenceItemId], references: [id], onDelete: Cascade)

  @@index([evidenceItemId])
  @@index([deletedAt])
}

// ── CAPA EFFECTIVENESS CRITERIA (substage 4.6) ──
// Measurable, time-bound success criteria defined per CAPA. Locked when the
// CAPA progresses to QA review (LOCKED_CAPA_STATUSES in src/lib/evidence-lock.ts);
// the lock mirrors EvidenceItem's pattern. lockedSignatureId stays null until
// the e-signature substage lands. Hard-deleted (no soft-delete column) — the
// audit trail captures the deletion event with the full pre-delete snapshot.
model CAPAEffectivenessCriterion {
  id                 String    @id @default(cuid())
  tenantId           String
  capaId             String

  description        String
  targetMetric       String
  measurementMethod  String
  targetValue        String
  monitoringPeriod   String

  createdBy          String
  createdAt          DateTime  @default(now())
  updatedBy          String?
  updatedAt          DateTime  @updatedAt

  lockedAt           DateTime?
  lockedBy           String?
  lockedSignatureId  String?

  capa               CAPA      @relation(fields: [capaId], references: [id], onDelete: Cascade)

  @@index([tenantId, capaId])
  @@index([capaId])
}

// ── SIGNED RECORDS (Part 11 §11.50, §11.70, §11.200) ──
// Polymorphic e-signature ledger. One row per discrete signing event —
// approval, revocation, closure, FDA 483 response, etc. Linked to the
// signed record via the (recordType, recordId) pair (no formal FK so the
// same table can serve every signing surface). The contentHash binds the
// signature to the signed record's canonical state at signing time, so
// any subsequent change to the underlying record is detectable. Rows
// here are immutable — never updated, never deleted.
model SignedRecord {
  id                  String    @id @default(cuid())
  tenantId            String

  // What was signed
  recordType          String    // "CAPA_APPROVAL" | "CAPA_APPROVAL_REVOCATION" | "CAPA_CLOSURE" | "FDA483_RESPONSE" | …
  recordId            String    // FK target id — polymorphic, no formal FK constraint

  // Who signed
  signerId            String
  signerName          String
  signerRole          String
  signerEmail         String    // captured at signing time (immutable even if user later changes email)

  // What the signature means (Part 11 §11.50)
  signatureMeaning    String    // "Approved" | "Rejected" | "Reviewed" | "Authored" | "Revoked" …

  // Integrity (Part 11 §11.50 — link signature to record)
  contentHash         String    // SHA-256 hex of the canonical record state at signing time
  contentSummary     String     // human-readable snapshot for audit display

  // Authentication metadata (Part 11 §11.200(a)(1)(ii))
  passwordVerifiedAt  DateTime  // exact moment password re-verification succeeded

  // Provenance — best-effort; not all server contexts provide these.
  ipAddress           String?
  userAgent           String?

  createdAt           DateTime  @default(now())

  approval                  CAPAApproval?
  // Back-references for substage 5.4 surfaces — each FK on the source
  // model is at most 1:1 with a SignedRecord row. ChangeControl.latest...
  // is N:1 (one SignedRecord backs at most one CC's "latest" pointer; the
  // CC's full history lives in (recordType, recordId) lookups). All are
  // nullable because the SignedRecord may also serve other recordTypes
  // (CAPA_APPROVAL, CAPA_APPROVAL_REVOCATION) that don't link back here.
  capaClosure               CAPA?            @relation("CAPAClosureSignature")
  fda483Response            FDA483Event?     @relation("FDA483ResponseSignature")
  documentApproval          Document?        @relation("DocumentApprovalSignature")
  deviationClosure          Deviation?       @relation("DeviationClosureSignature")
  changeControlTransition   ChangeControl[]  @relation("ChangeControlTransitionSignature")

  @@index([recordType, recordId])
  @@index([tenantId, signerId])
  @@index([createdAt])
}

// ── CAPA TIERED APPROVALS (substage 5.2) ──
// Count-based approval rows. The required count by risk tier lives in
// src/lib/capa-approvals.ts (APPROVAL_REQUIREMENTS). Each row captures one
// approver's verdict on the CAPA; the CAPA cannot be closed until the
// per-tier requirements are satisfied. signatureId stays null until the
// e-signature substage lands. Rows are hard-deleted via revokeCAPAApproval
// — the audit trail captures the snapshot in oldValue.
model CAPAApproval {
  id           String   @id @default(cuid())
  tenantId     String
  capaId       String

  approverRole String
  approverName String
  approverId   String
  approvedAt   DateTime @default(now())
  comment      String?
  // Substage 5.4 — Part 11 e-signature link. Required for new approvals
  // created by the post-substage-5.4 codepath; nullable to keep migrations
  // simple for any pre-existing approval rows that predate the e-sig
  // requirement. @@unique enforces the 1:1 — a given SignedRecord backs at
  // most one approval row (a revocation event creates a NEW SignedRecord).
  signatureId  String?  @unique
  signature    SignedRecord? @relation(fields: [signatureId], references: [id])

  // Revocation soft-delete — Part 11 records are immutable, so revokeCAPAApproval
  // marks the row revoked instead of deleting it. The revocation event itself
  // is also signed; revokedSignatureId points to the revocation SignedRecord
  // (kept as a free string so we don't need a second relation slot on
  // SignedRecord — the SignedRecord.recordId column links back via
  // recordType = "CAPA_APPROVAL_REVOCATION").
  revokedAt          DateTime?
  revokedSignatureId String?

  capa         CAPA     @relation(fields: [capaId], references: [id], onDelete: Cascade)

  @@index([tenantId, capaId])
  @@index([capaId])
  @@index([revokedAt])
}

// ── CAPA DISCUSSION THREAD (substage 5.2 §5.3) ──
// Threaded comments attached to a CAPA. Comments flagged as `isConcern` block
// final approval until resolved (see evaluateApprovalProgress in
// src/lib/capa-approvals.ts). Soft-delete only — Part 11 immutability; the
// "[deleted]" placeholder is rendered client-side, replies under a deleted
// parent stay visible.
model CAPAComment {
  id              String    @id @default(cuid())
  tenantId        String
  capaId          String
  parentId        String?

  body            String
  isConcern       Boolean   @default(false)

  resolvedAt      DateTime?
  resolvedById    String?
  resolvedByName  String?
  resolvedComment String?

  deletedAt       DateTime?
  deletedById     String?
  deletedByName   String?
  deletionReason  String?

  authorId        String
  authorName      String
  authorRole      String

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  capa            CAPA          @relation(fields: [capaId], references: [id], onDelete: Cascade)
  parent          CAPAComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies         CAPAComment[] @relation("CommentReplies")

  @@index([capaId, createdAt])
  @@index([tenantId, capaId])
  @@index([parentId])
}

// ── CHANGE CONTROL (substage 4.8) ──
// SOP, equipment, process, or product changes routed through Change Control
// with bidirectional CAPA traceability. Spec §4.8: "SOP/equipment/process
// changes routed through Change Control with bidirectional CAPA traceability."
//
// Reference scheme: CC-YYYY-NNN, per-tenant per-year sequence (mirrors
// CAPA.reference). Globally unique to match the existing CAPA pattern; the
// retry-on-P2002 logic in createChangeControl handles intra-tenant races.
//
// Soft-delete only — Part 11 immutability. Status state machine enforced
// at the action layer (transitionChangeControlStatus). Approval workflow
// here is intentionally simple (Draft → In Review → Approved …); the
// SignedRecord-backed signing pattern from substage 5.4 will be adopted
// for CC approvals later as a separate substage.
model ChangeControl {
  id              String    @id @default(cuid())
  tenantId        String
  reference       String?   @unique

  title           String
  description     String
  // Allowed values: "SOP" | "Equipment" | "Process" | "Product" |
  // "Computer System" | "Material" | "Other". Validated at the action
  // layer via zod (same pattern as CAPA.source / CAPA.risk).
  changeType      String
  rationale       String

  // Allowed values: "Critical" | "High" | "Medium" | "Low".
  risk            String
  impactAssessment String?
  affectedSystems String?

  // Allowed values: "Draft" | "In Review" | "Approved" |
  // "In Implementation" | "Implemented" | "Closed" | "Rejected".
  status          String    @default("Draft")

  owner           String
  ownerName       String

  targetImplementationDate DateTime?
  actualImplementationDate DateTime?
  closedAt        DateTime?
  closedById      String?
  closedByName    String?

  // Soft-delete metadata (Part 11 — never hard-delete).
  deletedAt       DateTime?
  deletedById     String?
  deletedByName   String?
  deletionReason  String?

  // Substage 5.4 — quick-lookup pointer at the most recent SignedRecord
  // backing a consequential transition (In Review→Approved, In Review→
  // Rejected, Implemented→Closed). Overwritten on each new consequential
  // transition; the full history lives in the SignedRecord ledger keyed by
  // (recordType="CHANGE_CONTROL_TRANSITION", recordId=<cc.id>) plus the
  // paired audit-log rows. NOT @@unique — multiple transitions can sign
  // against the same CC over its lifetime.
  latestSignedTransitionId String?

  createdBy       String
  createdByName   String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  capaLinks               CAPAChangeControlLink[]
  latestSignedTransition  SignedRecord?           @relation("ChangeControlTransitionSignature", fields: [latestSignedTransitionId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([deletedAt])
}

// Many-to-many join table between CAPA and ChangeControl. The
// `initiatedFrom` column records which side filed the link (so reverse
// queries can show "linked from this CC" vs "linked from this CAPA"
// without ambiguity). Hard-deleted on unlink — links are not Part 11
// records themselves; the audit trail is the immutable history.
model CAPAChangeControlLink {
  id              String    @id @default(cuid())
  tenantId        String

  capaId          String
  capa            CAPA      @relation(fields: [capaId], references: [id], onDelete: Cascade)

  changeControlId String
  changeControl   ChangeControl @relation(fields: [changeControlId], references: [id], onDelete: Cascade)

  // "CAPA" | "ChangeControl" — which side initiated the link.
  initiatedFrom   String

  linkRationale   String?

  linkedById      String
  linkedByName    String

  createdAt       DateTime  @default(now())

  @@unique([capaId, changeControlId])
  @@index([capaId])
  @@index([changeControlId])
  @@index([tenantId])
}

// ── EMAIL OTP (MFA) ──
// No FK: identifier resolves against either Tenant.email (super_admin / customer_admin)
// or User.email scoped by tenantId — a single FK can't model both. The composite
// (identifier, tenantId) lookup is sufficient; tenantId is null for Tenant-row
// matches and set for User-row matches.
model EmailOTP {
  id          String    @id @default(cuid())
  identifier  String
  tenantId    String?
  codeHash    String
  expiresAt   DateTime
  consumedAt  DateTime?
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([identifier, tenantId])
  @@index([expiresAt])
}
