  dueDate      DateTime?
  status       String    @default("Open")
  impact       String?
  mitigation   String?
  closedBy     String?
  closedAt     DateTime?
  reopenedBy   String?
  reopenedAt   DateTime?
  reopenReason String?
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ── INSPECTION READINESS ──

model Inspection {
