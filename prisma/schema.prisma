  statusManuallySetByName String?
  // Human-readable reference (generation wired in Rung 3; column added now).
  reference            String?   @unique
  // ── RUNG 2.6 — Part 11 validation sign-off snapshot ──
  // Set by signValidation() when QA signs off a fully-executed system; cleared
  // by unsignValidation(). The immutable e-signature itself lives in a
  // SignedRecord row (recordType "CSV_VALIDATION_SIGNOFF"); these denormalized
  // columns snapshot the system's state at the moment of sign-off for fast
  // display on the Sign Off / Inspect tabs without re-deriving history.
  signedOffAt               DateTime?
