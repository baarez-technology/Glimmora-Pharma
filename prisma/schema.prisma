generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── AUTH / TENANTS ──

model Tenant {
  id                  String   @id @default(cuid())
  customerCode        String   @unique
  name                String
  username            String   @unique
  email               String   @unique
  passwordHash        String
  role                String   @default("customer_admin")
  language            String   @default("en")
  timezone            String   @default("Asia/Kolkata")
  logoUrl             String?
  isActive            Boolean  @default(true)
  mfaEnabled          Boolean  @default(false)
  sessionsValidAfter  DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  subscription  Subscription?
  sites         Site[]
  users         User[]
  findings      Finding[]
  capas         CAPA[]
  deviations    Deviation[]
  fda483Events  FDA483Event[]
  systems       GxPSystem[]
  documents       Document[]
  raidItems       RAIDItem[]
  auditLogs       AuditLog[]
  inspections     Inspection[]
  playbooks       Playbook[]
  trainingRecords TrainingRecord[]
}

model Subscription {
  id          String   @id @default(cuid())
  tenantId    String   @unique
  maxAccounts Int      @default(5)
  startDate   DateTime
  expiryDate  DateTime
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ── SETTINGS ──

model Site {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  location  String?
  gmpScope  String?
  risk      String   @default("MEDIUM")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users      User[]
  findings   Finding[]
  capas      CAPA[]
  deviations Deviation[]

  @@unique([tenantId, name])
}

model User {
  id           String    @id @default(cuid())
  tenantId     String
  siteId       String?
  name         String
  email        String
  username     String
  passwordHash String
  role         String
  gxpSignatory Boolean   @default(false)
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site   Site?  @relation(fields: [siteId], references: [id])

  @@unique([tenantId, email])
  @@unique([tenantId, username])
}

// ── GAP ASSESSMENT ──

model Finding {
  id           String    @id @default(cuid())
  // Human-readable per-tenant identifier, e.g. "GAP-2026-014". Allocated by
  // createFinding's sequence-allocating transaction; nullable only for legacy
  // rows that predate the column. Globally @unique (same rationale as
  // CAPA.reference — see src/lib/reference.ts).
  reference    String?   @unique
  tenantId     String
  siteId       String?
  requirement  String
  // Why this gap matters / what closing it achieves. Surfaced in the report
  // form, register table, and detail view.
  purpose      String?
  area         String
  framework    String?
  severity     String
  status       String    @default("Open")
  owner        String
  targetDate   DateTime?
  rootCause    String?
  evidenceLink String?
  linkedCAPAId String?
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site   Site?         @relation(fields: [siteId], references: [id])
  capa   CAPA?
  edits  FindingEdit[]
}

// Append-only edit trail for findings (Part 11 ALCOA+). One row per save that
// changed at least one field. `changes` is a JSON-encoded array of
// { field, oldValue, newValue }. Never updated or deleted.
model FindingEdit {
  id           String   @id @default(cuid())
  findingId    String
  tenantId     String
  editedBy     String   // acting user id (resolved to a name in the UI)
  editedByName String
  editedAt     DateTime @default(now())
  reason       String?
  changes      String
  createdAt    DateTime @default(now())

  finding Finding @relation(fields: [findingId], references: [id], onDelete: Cascade)

  @@index([findingId])
}

// ── CAPA ──

model CAPA {
  id                 String    @id @default(cuid())
  // Human-readable per-tenant identifier, e.g. "CAPA-2026-014".
  // Nullable for the migration-then-backfill window; populated for every
  // row by the post-migration backfill, and for new rows by createCAPA's
  // sequence-allocating transaction. Uniqueness is enforced globally
  // (rather than per-tenant) because the cross-tenant collision space is
  // tiny — a tenant rarely creates >999 CAPAs in a year — and a global
  // unique index is cheaper to enforce in SQLite than a composite one.
  reference          String?   @unique
  tenantId           String
  siteId             String?
  findingId          String?   @unique
  source             String
  description        String
  risk               String
  owner              String
  dueDate            DateTime?
  // Valid values: "open" | "in_progress" | "pending_qa_review" | "closed" | "rejected".
  // Kept as String (not a Prisma enum) for SQLite portability — see
  // src/types/capa.ts for the canonical type and CAPA_STATUS_VALUES list.
  status             String    @default("open")
  rca                String?
  rcaMethod          String?
  correctiveActions  String?
  // ── Substage 4.7 — Action-to-Cause Alignment Review (manual reviewer flag) ──
  // alignmentStatus values: "aligned" | "cosmetic" | "needs_review" | null.
  // Validated at the application layer via ALIGNMENT_STATUSES in
  // src/lib/capa-alignment.ts (kept as String for SQLite portability —
  // same convention as EvidenceItem.status / CAPA.status). Override fields
  // capture separation-of-duties: a different qa_head (by id) can clear a
  // cosmetic flag for submission. Status changes always wipe the override
  // — a fresh review starts a fresh decision.
  alignmentStatus           String?
  alignmentReviewedBy       String?
  alignmentReviewedById     String?
  alignmentReviewedAt       DateTime?
  alignmentNotes            String?
  alignmentOverrideBy       String?
  alignmentOverrideById     String?
  alignmentOverrideAt       DateTime?
  alignmentOverrideReason   String?
  effectivenessCheck Boolean   @default(false)
  effectivenessDate  DateTime?
  diGate             Boolean   @default(false)
  diGateStatus       String?
  diGateNotes        String?
  diGateReviewedBy   String?
  diGateReviewDate   DateTime?
  closedBy           String?
  closedAt           DateTime?
  // Substage 6.4 — Linked CC dependency override metadata. Populated only
  // when a Medium/Low risk CAPA is marked implemented while linked Change
  // Controls are still incomplete and the owner has elected to override
  // the soft-gate. Critical/High CAPAs cannot use this — they hard-gate.
  // Stays null on the normal flow (all linked CCs Implemented or Closed).
  ccBlockOverrideReason   String?
  ccBlockOverrideById     String?
  ccBlockOverrideByName   String?
  ccBlockOverrideAt       DateTime?
  // Substage 5.4 — Part 11 e-signature link for the CAPA closure event.
  // Stays null until signAndCloseCAPA mints a SignedRecord; @@unique
  // enforces 1:1 with the SignedRecord row. Pre-existing CAPAs from
  // before this column landed remain null (legacy closures predate the
  // closure-signature requirement; the audit trail captures them).
  closureSignatureId String? @unique
  createdBy          String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant                 Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site                   Site?                        @relation(fields: [siteId], references: [id])
  finding                Finding?                     @relation(fields: [findingId], references: [id])
  closureSignature       SignedRecord?                @relation("CAPAClosureSignature", fields: [closureSignatureId], references: [id])
  documents              CAPADocument[]
  evidenceItems          EvidenceItem[]
  effectivenessCriteria  CAPAEffectivenessCriterion[]
  approvals              CAPAApproval[]
  comments               CAPAComment[]
  changeControlLinks     CAPAChangeControlLink[]
}

model CAPADocument {
  id          String    @id @default(cuid())
  capaId      String
  fileName    String
  fileSize    String?
  fileType    String?
  version     String    @default("v1.0")
  status      String    @default("current")
  uploadedBy  String
  approvedBy  String?
  approvedAt  DateTime?
  description String?
  createdAt   DateTime  @default(now())

  capa CAPA @relation(fields: [capaId], references: [id], onDelete: Cascade)
}

// ── DEVIATION ──

model Deviation {
  id                   String    @id @default(cuid())
  tenantId             String
  siteId               String?
  title                String
  description          String
  type                 String
  category             String
  severity             String
  area                 String
  detectedBy           String
  detectedDate         DateTime
  owner                String
  dueDate              DateTime?
  status               String    @default("open")
  immediateAction      String?
  rootCause            String?
  rcaMethod            String?
  patientSafetyImpact  String?
  productQualityImpact String?
  regulatoryImpact     String?
  batchesAffected      String?
  linkedCAPAId         String?
  closedBy             String?
  closedDate           DateTime?
  closureNotes         String?
  // Substage 5.4 — Part 11 e-signature link for the deviation closure
  // event. Null until closeDeviation mints a SignedRecord. Legacy closures
  // (predating this column) remain null.
  closureSignatureId   String?   @unique
  createdBy            String
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site              Site?          @relation(fields: [siteId], references: [id])
  closureSignature  SignedRecord?  @relation("DeviationClosureSignature", fields: [closureSignatureId], references: [id])
}

// ── FDA 483 ──

model FDA483Event {
  id               String    @id @default(cuid())
  tenantId         String
  referenceNumber  String
  eventType        String
  agency           String
  siteId           String
  inspectionDate   DateTime
  responseDeadline DateTime
  status           String    @default("Open")
  responseDraft    String?
  agiDraft         String?
  submittedAt      DateTime?
  submittedBy      String?
  signatureMeaning String?
  closedAt         DateTime?
  // Substage 5.4 — Part 11 e-signature link for the response submission
  // event. Null until signSubmitFDA483Response mints a SignedRecord.
  // Legacy submissions (predating this column) remain null.
  responseSignatureId String? @unique
  createdBy        String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant            Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  responseSignature SignedRecord?       @relation("FDA483ResponseSignature", fields: [responseSignatureId], references: [id])
  observations      FDA483Observation[]
  commitments       FDA483Commitment[]
  documents         FDA483Document[]
}

model FDA483Document {
  id         String   @id @default(cuid())
  eventId    String
  fileName   String
  fileUrl    String
  fileType   String?
  fileSize   String?
  type       String   @default("response")
  uploadedBy String
  createdAt  DateTime @default(now())

  event FDA483Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model FDA483Observation {
  id           String   @id @default(cuid())
  eventId      String
  number       Int
  text         String
  severity     String
  area         String?
  regulation   String?
  rcaMethod    String?
  rootCause    String?
  capaId       String?
  responseText String?
  status       String   @default("Open")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  event FDA483Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model FDA483Commitment {
  id      String    @id @default(cuid())
  eventId String
  text    String
  dueDate DateTime?
  owner   String?
  status  String    @default("Pending")

  event FDA483Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

// ── CSV/CSA ──

model GxPSystem {
  id               String   @id @default(cuid())
  tenantId         String
  name             String
  type             String
  vendor           String?
  version          String?
  gxpRelevance     String   @default("Major")
  part11Status     String   @default("N/A")
  annex11Status    String   @default("N/A")
  gamp5Category    String   @default("4")
  validationStatus String   @default("Not Started")
  riskLevel        String   @default("MEDIUM")
  siteId           String?
  intendedUse      String?
  gxpScope         String?
  plannedActions   String?
  owner            String?
  createdBy        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  validationStages  ValidationStage[]
  rtmEntries        RTMEntry[]
  roadmapActivities RoadmapActivity[]
}

model ValidationStage {
  id              String    @id @default(cuid())
  systemId        String
  stageName       String
  status          String    @default("not_started")
  notes           String?
  submittedBy     String?
  submittedDate   DateTime?
  approvedBy      String?
  approvedDate    DateTime?
  rejectedBy      String?
  rejectionReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  system    GxPSystem       @relation(fields: [systemId], references: [id], onDelete: Cascade)
  documents StageDocument[]
}

// CSV/CSA stage documents — Part 11 immutable, soft-delete only. Mirrors
// EvidenceFile (substage 3.2) but scoped to a ValidationStage rather than
// a CAPA's EvidenceItem. Locking is implicit: once the parent stage's
// status flips to "approved", the action layer rejects further uploads
// and deletes (no separate lockedAt column needed — the stage itself is
// the lock signal).
model StageDocument {
  id                String    @id @default(cuid())
  tenantId          String

  validationStageId String
  validationStage   ValidationStage @relation(fields: [validationStageId], references: [id], onDelete: Cascade)

  fileName          String    // sanitized stored name
  originalFileName  String    // user's upload name (post-sanitize, kept for audit)
  fileSize          Int       // bytes
  fileType          String    // MIME type
  fileUrl           String    // storage key relative to fileStorage root
  contentHashSha256 String    // SHA-256 hex of file contents at upload time

  retainUntil       DateTime  // upload + 7 years (Part 11 retention floor)

  // Soft delete — Part 11 §11.10(e). Bytes survive on disk; row stays.
  deletedAt         DateTime?
  deletedById       String?
  deletedByName     String?
  deletionReason    String?

  uploadedById      String
  uploadedByName    String
  uploadedAt        DateTime  @default(now())

  @@index([validationStageId])
  @@index([tenantId, uploadedAt])
  @@index([deletedAt])
}

model RTMEntry {
  id                 String   @id @default(cuid())
  systemId           String
  ursId              String
  ursRequirement     String
  ursRegulation      String?
  ursPriority        String   @default("high")
  fsReference        String?
  fsStatus           String   @default("missing")
  dsReference        String?
  dsStatus           String   @default("na")
  iqTestId           String?
  iqResult           String?
  oqTestId           String?
  oqResult           String?
  pqTestId           String?
  pqResult           String?
  evidenceStatus     String   @default("missing")
  traceabilityStatus String   @default("broken")
  linkedFindingId    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  system GxPSystem @relation(fields: [systemId], references: [id], onDelete: Cascade)
}

model RoadmapActivity {
  id             String    @id @default(cuid())
  systemId       String
  title          String
  type           String
  status         String    @default("Planned")
  startDate      DateTime?
  endDate        DateTime?
  owner          String?
  completionType String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  system GxPSystem @relation(fields: [systemId], references: [id], onDelete: Cascade)
}

// ── EVIDENCE ──

// Document — being unified into the cross-module attachment store.
//
// Phase 1.3a (this migration `unify_documents_phase1`):
//   • Adds 11 nullable columns alongside the legacy ones.
//   • Legacy columns (linkedModule, linkedRecordId, fileType, fileSize,
//     createdAt, status default "draft") are kept untouched so existing
//     callers (createDocument metadata-only path) keep working.
//
// Phase 1.3b (next migration, after Session 2 backfill):
//   • Backfill sourceModule/sourceId/sha256/storageKey/etc. from
//     linkedModule/linkedRecordId/EvidenceFile joins.
//   • Rename fileType → mimeType, createdAt → uploadedAt; drop the
//     legacy linkedModule/linkedRecordId; retype fileSize String → Int;
//     promote sourceModule/sourceId/sha256/storageKey/originalFileName/
//     mimeType/retainUntil/fileSize to NOT NULL.
//   • Add siteId/category as nullable; add (tenantId, uploadedAt) index;
//     flip status default to "Pending".
model Document {
  id             String    @id @default(cuid())
  tenantId       String

  // ── Legacy columns (1.3a keeps intact; 1.3b backfills + drops/renames) ──
  fileName       String
  fileType       String?
  fileSize       String?
  version        String    @default("v1.0")
  status         String    @default("draft")
  description    String?
  linkedModule   String?
  linkedRecordId String?
  uploadedBy     String
  approvedBy     String?
  approvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // ── 1.3a additions — all nullable for now ──
  sourceModule     String?
  sourceId         String?
  siteId           String?
  category         String?
  sha256           String?
  storageKey       String?
  originalFileName String?
  fileExtension    String?
  retainUntil      DateTime?
  deletedAt        DateTime?
  deletedBy        String?
  deletionReason   String?
  notes            String?
  // New canonical timestamp — written by the Phase 2 upload service.
  // 1.3b backfills NULLs from createdAt, marks NOT NULL, then drops createdAt.
  uploadedAt       DateTime?
  // Substage 5.4 — Part 11 e-signature link for the document approval
  // event. Null until approveDocument mints a SignedRecord.
  approvalSignatureId String? @unique

  tenant             Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  approvalSignature  SignedRecord?  @relation("DocumentApprovalSignature", fields: [approvalSignatureId], references: [id])

  @@index([tenantId, sourceModule, sourceId])
  @@index([tenantId, uploadedAt])
  @@index([sha256])
  @@index([deletedAt])
}

// ── GOVERNANCE ──

model RAIDItem {
  id           String    @id @default(cuid())
  tenantId     String
  type         String
  title        String
  description  String
  priority     String
