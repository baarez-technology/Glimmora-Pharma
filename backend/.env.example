# Glimmora Pharma — AI Backend environment variables
#
# Copy to backend/.env and fill in real values.
# backend/.env is gitignored.

# ─── Database ─────────────────────────────────────────────────────────────
# Dev:  sqlite:///./glimmora.db
# Prod: postgresql://user:password@host:5432/glimmora_ai?sslmode=require
DATABASE_URL=sqlite:///./glimmora.db

# ─── AI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
PINECONE_API_KEY=

# ─── Auth (JWT) ───────────────────────────────────────────────────────────
# Must match JWT_SECRET on the Next.js side if cross-verifying tokens.
JWT_SECRET=replace-with-a-strong-secret

# ─── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Dev default: http://localhost:3000
# Prod: set to the DO App Platform URL (web service handles this internally)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
